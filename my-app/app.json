{
  "expo": {
    "name": "FishLog",
    "slug": "fishlog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fishlog",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tulodziecki.fishlog",
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "package": "com.tulodziecki.fishlog",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "backgroundColor": "#042C53"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#042C53",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 120
          },
          "ios": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 120
          }
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9608aec0-ef04-4ca0-88a6-e53258c152d8"
      }
    },
    "owner": "tu_szymon"
  }
}
